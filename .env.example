# Copy to .env.local for local development.
# On Netlify: Site configuration → Environment variables (same names).
# After changing these on Netlify, trigger "Clear cache and deploy site".
#
# NEXT_PUBLIC_FIREBASE_API_KEY is a public client key (not a server secret).
# Netlify secret scanning is configured in netlify.toml to allow it in build output.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
